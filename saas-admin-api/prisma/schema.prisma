generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
}

enum SerialType {
  ANDROID
  WEB
}

enum ProvisioningStatus {
  PENDING
  READY
  ERROR
}

enum LicenseType {
  SAAS
  DESKTOP_OFFLINE_LIFETIME
  TRIAL
}

model Tenant {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String
  ownerName          String?            @map("owner_name")
  phone              String?
  email              String?
  subdomain          String             @unique
  frontendUrl        String?            @map("frontend_url")
  backendUrl         String             @map("backend_url")
  customDomain       String?            @unique @map("custom_domain")
  status             TenantStatus       @default(ACTIVE)
  provisioningStatus ProvisioningStatus @default(PENDING) @map("provisioning_status")
  provisioningError  String?            @map("provisioning_error")
  notes              String?

  // ── Batch 1: license / entitlements model (additive, all nullable/default) ──
  licenseType        LicenseType        @default(SAAS) @map("license_type")
  activatedAt        DateTime?          @map("activated_at")
  expiresAt          DateTime?          @map("expires_at")
  trialEndsAt        DateTime?          @map("trial_ends_at")
  // Optional feature keys enabled on top of the always-on base version.
  features           String[]           @default([])
  // { maxAndroidDevices, whatsappMonthlyLimit, whatsappLimitEnabled }
  limits             Json?
  // { webEnabled, androidEnabled, desktopEnabled, desktopWhiteLabelEnabled, offlineLifetimeEnabled }
  platforms          Json?
  // { storeName, logoUrl, primaryColor, appName }
  branding           Json?
  // Super-admin only notes; never returned by public endpoints.
  internalNotes      String?            @map("internal_notes")
  // { androidApkUrl, desktopInstallerUrl, desktopVersion, androidVersion, buildStatus, lastBuildAt }
  installerArtifacts Json?              @map("installer_artifacts")

  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  subscriptions Subscription[]
  serialNumbers SerialNumber[]
  auditLogs      AdminAuditLog[]

  @@map("tenants")
}

model Subscription {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan         String    // "TRIAL" | "BASIC" | "FULL"
  startsAt     DateTime  @default(now()) @map("starts_at")
  expiresAt    DateTime? @map("expires_at")
  maxInvoices  Int?      @map("max_invoices")
  maxCustomers Int?      @map("max_customers")
  maxUsers     Int?      @map("max_users")
  maxWarehouses Int?     @map("max_warehouses")
  maxAndroidDevices Int? @map("max_android_devices")
  features     String[]  // ["ANDROID","CATALOG","AI","MULTI_WAREHOUSE"]
  price        Float?
  currency     String    @default("IQD")
  billingCycle String    @default("MONTHLY") @map("billing_cycle")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("subscriptions")
}

model SerialNumber {
  id           String     @id @default(uuid()) @db.Uuid
  code         String     @unique
  tenantId     String     @map("tenant_id") @db.Uuid
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type         SerialType @default(ANDROID)
  label        String?    // e.g. "Warehouse device", "Main store"
  activatedAt  DateTime?  @map("activated_at")
  activatedBy  String?    @map("activated_by") // device fingerprint
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@map("serial_numbers")
}

model AdminUser {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admin_users")
}

model AdminAuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String?  @map("tenant_id") @db.Uuid
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  adminId   String?  @map("admin_id") @db.Uuid
  action    String
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}
