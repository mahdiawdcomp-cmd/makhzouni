{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "مخزوني مهدي عوض",
  "version": "1.0.7",
  "identifier": "com.mazbwoni.mahdi",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "مخزوني مهدي عوض",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "center": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:5050 https://inventory-backend-production-7e85.up.railway.app https://api.mazbwoni.com https://mahdi.mazbwoni.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:;"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUwNzRGODhBOEQxOTUzNTcKUldSWFV4bU5pdmgwVUh0NXNuUkFoNkpKbGRKTS9TODdmN1duYWN1VVJreVZSQXZrc2YveWVid08K",
      "endpoints": [
        "https://github.com/mahdiawdcomp-cmd/makhzouni/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/query_engine-windows.dll.node"
    ],
    "externalBin": [
      "binaries/server"
    ]
  }
}
