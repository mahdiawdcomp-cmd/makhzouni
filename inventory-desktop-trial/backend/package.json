{
  "name": "inventory-backend",
  "version": "1.0.0",
  "description": "Backend server for inventory and accounting management.",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && node -e \"const fs=require('fs');fs.mkdirSync('dist/src/assets',{recursive:true});try{fs.cpSync('src/assets','dist/src/assets',{recursive:true})}catch(e){};try{fs.copyFileSync('node_modules/.prisma/client/query_engine-windows.dll.node','dist/src/query_engine-windows.dll.node')}catch(e){};try{fs.mkdirSync('dist/src/migrations',{recursive:true});fs.copyFileSync('prisma/migrations/20260623025926_init/migration.sql','dist/src/migration.sql')}catch(e){}\"",
    "build:exe": "npm run build && pkg dist/src/server.js --target node22-win-x64 --output bin/server.exe --compress GZip",
    "test": "node --experimental-test-module-mocks --import tsx --test \"src/**/*.test.ts\"",
    "start": "node dist/src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts"
  },
  "pkg": {
    "assets": [
      "node_modules/.prisma/client/*.node",
      "node_modules/@prisma/engines/*.node",
      "node_modules/@img/sharp-win32-x64/lib/*",
      "node_modules/@img/sharp-win32-x64/package.json",
      "prisma/schema.prisma",
      "dist/src/migration.sql"
    ],
    "scripts": [
      "dist/src/**/*.js"
    ]
  },
  "keywords": [
    "inventory",
    "accounting",
    "express",
    "prisma",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "@types/multer": "^2.1.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dayjs": "^1.11.21",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "groq-sdk": "^1.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "whatsapp-web.js": "^1.34.7",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.15.21",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@yao-pkg/pkg": "^6.20.0",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
