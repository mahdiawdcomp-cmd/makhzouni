DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
PORT=5000
INITIAL_ADMIN_NAME="مدير النظام"
INITIAL_ADMIN_USERNAME="admin"
INITIAL_ADMIN_PASSWORD="replace-with-a-strong-password"
NODE_ENV=development
ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
JWT_SECRET="replace-with-256-bit-random-secret"
JWT_EXPIRES_IN="30d"
BCRYPT_SALT_ROUNDS=10
ENABLE_WHATSAPP=false
CHROME_PATH=""
# Use the official Meta WhatsApp Cloud API instead of QR/WhatsApp Web.
# Set WHATSAPP_PROVIDER=cloud in production when these values are configured.
WHATSAPP_PROVIDER=web
WHATSAPP_CLOUD_TOKEN=""
WHATSAPP_CLOUD_PHONE_NUMBER_ID=""
WHATSAPP_CLOUD_GRAPH_VERSION="v20.0"
API_RATE_LIMIT_PER_MINUTE=100
LOGIN_RATE_LIMIT_PER_15_MINUTES=5
REFRESH_RATE_LIMIT_PER_MINUTE=20
